# Supabase (optional - app falls back to local demo mode if absent)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Server-side only: used by the Supabase Edge Function to persist rows.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=4173
NODE_ENV=development
